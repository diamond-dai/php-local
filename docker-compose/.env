# コンテナにつくプレフィックス、プロジェクトごとに一意にする
COMPOSE_PROJECT_NAME=php-local

# httpd
HTTPD_BIND=127.0.0.1
HTTPD_PORT=60000

# Database
# PHPアプリが接続するユーザー（adminerの自動ログインにも使う）
DB_HOST=db
DB_USER=app
DB_PASSWORD=app
DB_NAME=app
# MariaDB初期化用。MYSQL_USER/MYSQL_PASSWORDでDB_USERと同じユーザーを作成する
# （DB_*と値を揃えること。揃えないとアプリがDB接続できない）
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_ROOT_PASSWORD=root

# Timezone
TZ=Asia/Tokyo
